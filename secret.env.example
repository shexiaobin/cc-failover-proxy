# Copy this file to `secret.env` and fill in your values.
# `secret.env` is gitignored — never commit real tokens.

# --- Fallback upstream (required to enable failover) ---
# An Anthropic-Messages-API-compatible endpoint to fall back to when your
# primary (OAuth subscription) returns 429/529. Example shape:
#   HUB_BASE=https://your-gateway.example.com/anthropic/v1
HUB_BASE=
HUB_TOKEN=

# Optional: if your fallback expects a specific model name, set it and the
# proxy will rewrite the `model` field on the fallback leg. Leave empty to
# pass the model through unchanged.
HUB_MODEL=

# --- Optional tuning (have sane defaults) ---
# PROXY_PORT=8788
# COOLDOWN_SEC=300
# PRIMARY_BASE=https://api.anthropic.com

# Optional: command the watchdog runs on a state change (healthy<->unhealthy).
# It is invoked as:  $NOTIFY_CMD "<message>"
# Example: a script that posts to Slack / a chat bridge / sends a desktop notif.
# NOTIFY_CMD=
